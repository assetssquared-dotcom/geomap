{
  "rewrites": [
    { "source": "/api/news", "destination": "/api/news.js" },
    { "source": "/api/country-updates", "destination": "/api/country-updates.js" },
    { "source": "/api/cron-update", "destination": "/api/cron-update.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-update",
      "schedule": "0 0 * * *"
    }
  ]
}
